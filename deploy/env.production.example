APP_NAME="Loyalty App"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://159.89.111.79
FRONTEND_URL=http://159.89.111.79

LOG_CHANNEL=stack
LOG_LEVEL=warning
BROADCAST_CONNECTION=reverb

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=loyalty_app
DB_USERNAME=loyalty
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Leave as localhost only — app uses Bearer tokens, not cookie SPA auth.
# Including your prod IP/domain here causes CSRF mismatch on /api/auth/login.
SANCTUM_STATEFUL_DOMAINS=127.0.0.1,localhost

CACHE_STORE=database
QUEUE_CONNECTION=database

REVERB_APP_ID=loyalty-prod-app
REVERB_APP_KEY=CHANGE_ME_REVERB_KEY
REVERB_APP_SECRET=CHANGE_ME_REVERB_SECRET
REVERB_HOST=159.89.111.79
REVERB_BROADCAST_HOST=159.89.111.79
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
