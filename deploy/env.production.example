APP_NAME="Flotory"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://flotory.com
FRONTEND_URL=https://flotory.com

LOG_CHANNEL=stack
LOG_LEVEL=warning
BROADCAST_CONNECTION=reverb

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=flotory_app
DB_USERNAME=flotory
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# Matches `name: flotory` in docker-compose.prod.yml (containers: flotory-app-1, …).
COMPOSE_PROJECT_NAME=flotory

ADMIN_EMAIL=admin@flotory.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.flotory.com
SESSION_SECURE_COOKIE=true
# Production browser auth domains.
SANCTUM_STATEFUL_DOMAINS=flotory.com,www.flotory.com

CACHE_STORE=database
QUEUE_CONNECTION=database

REVERB_APP_ID=flotory-prod-app
REVERB_APP_KEY=CHANGE_ME_REVERB_KEY
REVERB_APP_SECRET=CHANGE_ME_REVERB_SECRET
# Public hostname for browser WebSocket clients (nginx proxies /app/ on 443).
REVERB_HOST=flotory.com
# Docker service name for server-side broadcast from the app container.
REVERB_BROADCAST_HOST=reverb
REVERB_BROADCAST_SCHEME=http
REVERB_PORT=8080
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
# Browser connects via nginx on 443, not Reverb's exposed 8080 port.
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

FRONTEND_URL="https://flotory.com"

MAIL_MAILER=resend
MAIL_FROM_ADDRESS="team@flotory.com"
MAIL_FROM_NAME="Flotory"
RESEND_API_KEY=

GOOGLE_CLIENT_ID=84096793496-0qd1h271dstqfvn4k7hd6hvso0dtbneu.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="https://flotory.com/auth/google/callback"
# Browser-restricted key (Maps JavaScript API + Places API). Referrers: https://flotory.com/*
GOOGLE_MAPS_API_KEY=

# Owner demo booking — paste your Calendly event URL after creating a free account.
FLOTORY_DEMO_CALENDLY_URL=https://calendly.com/flotoryapp/30min
FLOTORY_DEMO_NOTIFY_EMAIL=team@flotory.com
