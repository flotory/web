APP_NAME="Flotory"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://flotory.com
FRONTEND_URL=https://flotory.com

LOG_CHANNEL=stack
LOG_LEVEL=warning
BROADCAST_CONNECTION=null

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=flotory_app
DB_USERNAME=flotory
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# Matches `name: flotory` in docker-compose.prod.yml (containers: flotory-app-1, …).
COMPOSE_PROJECT_NAME=flotory

ADMIN_EMAIL=admin@flotory.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.flotory.com
SESSION_SECURE_COOKIE=true
# Production browser auth domains.
SANCTUM_STATEFUL_DOMAINS=flotory.com,www.flotory.com

CACHE_STORE=database
QUEUE_CONNECTION=database

FRONTEND_URL="https://flotory.com"

MAIL_MAILER=resend
MAIL_FROM_ADDRESS="team@flotory.com"
MAIL_FROM_NAME="Flotory"
RESEND_API_KEY=

GOOGLE_CLIENT_ID=84096793496-0qd1h271dstqfvn4k7hd6hvso0dtbneu.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="https://flotory.com/auth/google/callback"
# Browser-restricted key (Maps JavaScript API + Places API). Referrers: https://flotory.com/*
GOOGLE_MAPS_API_KEY=

# Owner demo booking — paste your Calendly event URL after creating a free account.
FLOTORY_DEMO_CALENDLY_URL=https://calendly.com/flotoryapp/30min
