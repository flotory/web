APP_NAME="Flotory"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://flotory.com
FRONTEND_URL=https://flotory.com

LOG_CHANNEL=stack
LOG_LEVEL=warning
BROADCAST_CONNECTION=reverb

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=flotory_app
DB_USERNAME=flotory
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.flotory.com
# Production browser auth domains.
SANCTUM_STATEFUL_DOMAINS=flotory.com,www.flotory.com

CACHE_STORE=database
QUEUE_CONNECTION=database

REVERB_APP_ID=flotory-prod-app
REVERB_APP_KEY=CHANGE_ME_REVERB_KEY
REVERB_APP_SECRET=CHANGE_ME_REVERB_SECRET
REVERB_HOST=flotory.com
REVERB_BROADCAST_HOST=flotory.com
REVERB_PORT=8080
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
