# Copy to .env.secrets on each computer (gitignored).
# Keep the same values on both machines — store in a password manager.
#
#   cp .env.secrets.example .env.secrets
#
# Then run: ./scripts/setup-local.sh

GOOGLE_CLIENT_SECRET=
# Browser key — Maps JavaScript API + Places API. Referrers: http://localhost:8000/*
VITE_GOOGLE_MAPS_API_KEY=
# Server key — Time Zone API for venue timezone lookup from Laravel.
GOOGLE_MAPS_SERVER_API_KEY=
RESEND_API_KEY=
