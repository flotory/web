{
  "expo": {
    "name": "Flotory",
    "slug": "flotory-mobile",
    "newArchEnabled": false,
    "version": "1.0.14",
    "orientation": "portrait",
    "icon": "./assets/flotory-app-icon-padded.png",
    "splash": {
      "image": "./assets/android-icon-foreground.png",
      "resizeMode": "contain",
      "backgroundColor": "#FCFAF6"
    },
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.flotory.mobile",
      "buildNumber": "15",
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDisplayName": "Flotory",
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Flotory uses your location to show nearby venues and distances.",
        "NFCReaderUsageDescription": "Flotory reads NFC stamp stands at cafes and restaurants to add loyalty stamps to your wallet."
      },
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": ["TAG"]
      }
    },
    "android": {
      "package": "com.flotory.mobile",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#050D1E",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "flotory",
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/android-icon-foreground.png",
          "imageWidth": 154,
          "resizeMode": "contain",
          "backgroundColor": "#FCFAF6"
        }
      ],
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Flotory uses your location to show nearby venues and distances."
        }
      ],
      "expo-web-browser",
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "Flotory reads NFC stamp stands at cafes and restaurants to add loyalty stamps to your wallet.",
          "includeNdefEntitlement": false
        }
      ],
      "./plugins/withNfc.js",
      "./plugins/withIosBuildFixes.js"
    ]
  }
}
