{
  "expo": {
    "name": "Flotory Mobile",
    "slug": "flotory-mobile",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/flotory-app-icon-padded.png",
    "splash": {
      "image": "./assets/flotory-boot-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F2E8"
    },
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.flotory.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Flotory uses your location to show nearby venues and distances."
      }
    },
    "android": {
      "package": "com.flotory.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#081233",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "flotory",
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/flotory-boot-splash.png",
          "imageWidth": 400,
          "resizeMode": "contain",
          "backgroundColor": "#F7F2E8"
        }
      ],
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Flotory uses your location to show nearby venues and distances."
        }
      ]
    ]
  }
}
