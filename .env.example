APP_NAME="Flotory"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# Laravel app URL — used for Google OAuth return and post-login redirects (not the Vite port).
FRONTEND_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug
BROADCAST_CONNECTION=reverb

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=flotory_app
DB_USERNAME=flotory
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000,localhost:5173,127.0.0.1:5173

CACHE_STORE=database
QUEUE_CONNECTION=database

REVERB_APP_ID=flotory-local-app
REVERB_APP_KEY=flotory-local-key
REVERB_APP_SECRET=flotory-local-secret
REVERB_HOST=localhost
REVERB_BROADCAST_HOST=host.docker.internal
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
VITE_HMR_HOST=localhost
VITE_DEV_SERVER_URL=http://localhost:5173

# Use Resend for real delivery. Set RESEND_API_KEY in .env.secrets (see scripts/setup-local.sh).
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="team@flotory.com"
MAIL_FROM_NAME="Flotory"
RESEND_API_KEY=

# Public client id is fine in git; put GOOGLE_CLIENT_SECRET in .env.secrets (see scripts/setup-local.sh).
GOOGLE_CLIENT_ID=84096793496-0qd1h271dstqfvn4k7hd6hvso0dtbneu.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Keep Docker volumes when the folder was renamed from "Loyalty App"
COMPOSE_PROJECT_NAME=loyaltyapp
