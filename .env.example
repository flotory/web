APP_NAME="Flotory"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# Laravel app URL — used for Google OAuth return and post-login redirects (not the Vite port).
FRONTEND_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug
BROADCAST_CONNECTION=null

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=flotory_app
DB_USERNAME=flotory
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000,localhost:5173,127.0.0.1:5173

CACHE_STORE=database
QUEUE_CONNECTION=database

VITE_HMR_HOST=localhost
# Host port for the Docker `vite` service (container still listens on 5173).
# If 5173 is taken (another project's dev server), use ./scripts/docker-up.sh — it picks 5174+ automatically.
VITE_HOST_PORT=5173
VITE_DEV_SERVER_URL=http://localhost:5173

# Use Resend for real delivery. Set RESEND_API_KEY in .env.secrets (see scripts/setup-local.sh).
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="team@flotory.com"
MAIL_FROM_NAME="Flotory"
RESEND_API_KEY=

# Public client id is fine in git; put GOOGLE_CLIENT_SECRET in .env.secrets (see scripts/setup-local.sh).
GOOGLE_CLIENT_ID=84096793496-0qd1h271dstqfvn4k7hd6hvso0dtbneu.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
# Browser-restricted key for Places address autocomplete (Maps JavaScript API + Places API).
VITE_GOOGLE_MAPS_API_KEY=
# Server key for Laravel Time Zone API (venue campaign schedules). Enable Time Zone API in Google Cloud.
# IP-restrict to your droplet in production; can match browser key locally if unrestricted.
GOOGLE_MAPS_SERVER_API_KEY=
# Legacy alias — used when GOOGLE_MAPS_SERVER_API_KEY is empty.
GOOGLE_MAPS_API_KEY=

# Optional override; compose files also set `name: flotory` for container names like flotory-app-1.
COMPOSE_PROJECT_NAME=flotory

# Super admin (local demo). Override in production .env — use a strong ADMIN_PASSWORD.
ADMIN_EMAIL=admin@flotory.com
ADMIN_PASSWORD=password

# Owner demo booking — Calendly event link (Event types → Copy link).
FLOTORY_DEMO_CALENDLY_URL=https://calendly.com/flotoryapp/30min

# Mobile app compatibility (optional). When force_update=true, outdated app builds are blocked on launch.
# FLOTORY_MIN_IOS_VERSION=1.0.13
# FLOTORY_MIN_ANDROID_VERSION=1.0.13
# FLOTORY_FORCE_UPDATE=false
# FLOTORY_IOS_UPDATE_URL=https://flotory.com/app
# FLOTORY_ANDROID_UPDATE_URL=https://flotory.com/app
