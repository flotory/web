{
  "name": "flotory-web",
  "version": "1.0.0",
  "description": "Restaurant loyalty SaaS platform built with Laravel, Vue, TailwindCSS, and shadcn-vue style components.",
  "private": true,
  "main": "resources/js/app.ts",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "check:web": "npm run typecheck && vite build && npm run test:unit -- resources/js",
    "test:unit": "vitest run",
    "test:unit:web": "vitest run resources/js",
    "test:e2e": "playwright test",
    "test:e2e:local": "./scripts/e2e-local.sh",
    "test:mobile:e2e": "bash scripts/run-mobile-e2e.sh",
    "test:mobile:e2e:flows": "maestro test .maestro/mobile",
    "icons:generate": "python3 scripts/generate-brand-icons.py"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "module",
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cropperjs": "^1.6.2",
    "laravel-vite-plugin": "^3.1.0",
    "libphonenumber-js": "^1.13.3",
    "pinia": "^3.0.4",
    "qrcode.vue": "^3.9.1",
    "reka-ui": "^2.9.8",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.3.2"
  }
}
